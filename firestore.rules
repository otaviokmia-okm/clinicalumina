
/**
 * LUMINA AESTHETICS - FIRESTORE SECURITY RULES
 * Versão otimizada para o protótipo.
 */

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    // --- Collection Rules ---

    match /services/{serviceId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /clients/{clientId} {
      allow read, write: if isSignedIn();
    }

    match /appointments/{appointmentId} {
      // Aberto para leitura para permitir que visitantes vejam horários ocupados
      // e o administrador veja a agenda completa.
      allow read: if true;
      
      // Permitir criação e atualização para usuários autenticados (incluindo anônimos)
      allow create, update, delete: if isSignedIn();
    }

    match /admin_roles/{adminId} {
      allow get: if isSignedIn() && request.auth.uid == adminId;
      allow list, create, update, delete: if false;
    }
  }
}
