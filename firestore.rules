/**
 * LUMINA AESTHETICS - FIRESTORE SECURITY RULES
 *
 * Core Philosophy:
 * This ruleset implements a dual-layered security model: strict administrative control via 
 * Database Access Control (DBAC) for clinic management, and a user-ownership model for 
 * clients managing their own appointments. It prioritizes data privacy while allowing 
 * public visibility of services.
 *
 * Data Structure:
 * - /services: Publicly accessible catalog of clinic offerings.
 * - /clients: Internal CRM records managed by administrators.
 * - /appointments: Shared collection where clients book services and admins manage the clinic schedule.
 * - /admin_roles: A control collection where the existence of a UID grants administrative privileges.
 *
 * Key Security Decisions:
 * - Admin Authorization: Leverages a high-performance existence check on the `admin_roles` collection.
 * - Ownership Denormalization: The `Appointment` document explicitly stores `clientId` to 
 *   enable fast, non-hierarchical ownership checks and secure list queries.
 * - Flexible Prototyping: While authorization is strictly enforced based on identity and roles, 
 *   data schema validation is omitted to support rapid iteration of features like appointment status 
 *   updates and rescheduling.
 * - Immutability: Relational links (like `clientId` on an appointment) are enforced as 
 *   immutable to prevent unauthorized data re-assignment.
 */

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    /**
     * @description Checks if the user is authenticated.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Checks if the authenticated user has administrative privileges 
     * by verifying their UID exists in the admin_roles collection.
     */
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admin_roles/$(request.auth.uid));
    }

    /**
     * @description Checks if the authenticated user's UID matches the provided ID.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * @description Verifies ownership of an existing document before modification or deletion.
     * @param userId The UID to check against.
     */
    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    /**
     * @description Checks if the incoming data preserves the original owner.
     */
    function isOwnerImmutable(ownerField) {
      return request.resource.data[ownerField] == resource.data[ownerField];
    }

    // --- Collection Rules ---

    /**
     * @description Manages aesthetic services. Readable by all, writable only by admins.
     * @path /services/{serviceId}
     * @allow (get, list) for any user, (create, update, delete) if user is admin.
     * @deny (write) if user is not an admin.
     * @principle Public Read with Owner-Only Writes (Admin as Owner).
     */
    match /services/{serviceId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    /**
     * @description Internal CRM records of clients. Access restricted to administrators.
     * @path /clients/{clientId}
     * @allow (all) if user is an admin.
     * @deny (all) if user is not an admin.
     * @principle Administrative segregation for sensitive CRM data.
     */
    match /clients/{clientId} {
      allow get, list, create, update, delete: if isAdmin();
    }

    /**
     * @description Secure management of appointments linking clients to services.
     * @path /appointments/{appointmentId}
     * @allow (create) if owner matches clientId, (get, list, update) if user is owner or admin.
     * @deny (update) if trying to change the clientId, (delete) if not admin or owner.
     * @principle Ownership-based authorization via denormalized clientId.
     */
    match /appointments/{appointmentId} {
      // Allow read if Admin OR if the appointment belongs to the user
      allow get: if isAdmin() || (isSignedIn() && resource.data.clientId == request.auth.uid);
      
      // Allow listing if Admin or Signed In (Query-As-Permissions requires the query to filter by clientId)
      allow list: if isAdmin() || isSignedIn();

      // Clients can create appointments for themselves; Admins can create for anyone.
      allow create: if isAdmin() || (isSignedIn() && request.resource.data.clientId == request.auth.uid);

      // Updates (Confirming, Rescheduling) allowed for owners and admins.
      // Relational integrity: The clientId must remain immutable.
      allow update: if resource != null && (isAdmin() || (isExistingOwner(resource.data.clientId) && isOwnerImmutable('clientId')));

      // Deletion is a state-changing operation requiring existence check.
      allow delete: if resource != null && (isAdmin() || isExistingOwner(resource.data.clientId));
    }

    /**
     * @description Database Access Control (DBAC) mapping for administrative roles.
     * @path /admin_roles/{adminId}
     * @allow (get) for the admin themselves to check their status.
     * @deny (list, create, update, delete) to prevent privilege escalation or directory listing.
     * @principle Token-based identity verification via document existence.
     */
    match /admin_roles/{adminId} {
      allow get: if isOwner(adminId) || isAdmin();
      allow list: if false;
      allow create, update, delete: if false;
    }
  }
}