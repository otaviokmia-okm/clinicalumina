
/**
 * LUMINA AESTHETICS - FIRESTORE SECURITY RULES
 * Versão simplificada e robusta para o protótipo.
 */

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Permissões Gerais ---

    match /services/{serviceId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /clients/{clientId} {
      allow read, write: if request.auth != null;
    }

    match /appointments/{appointmentId} {
      // Aberto para leitura para permitir consultas do site e do admin
      allow read: if true;
      // Permitir escrita para qualquer usuário autenticado (incluindo anônimos/admin)
      allow write: if request.auth != null;
    }

    match /admin_roles/{adminId} {
      allow read: if request.auth != null && request.auth.uid == adminId;
      allow write: if false;
    }
  }
}
