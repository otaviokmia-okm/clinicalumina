/**
 * LUMINA AESTHETICS - FIRESTORE SECURITY RULES (PROTOTYPE VERSION)
 *
 * Ajustado para permitir que o administrador acesse e gerencie agendamentos
 * mesmo com login anônimo/demonstração.
 */

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      // Para o protótipo, permitimos que qualquer usuário autenticado no painel admin
      // possa gerenciar, ou mantemos a verificação de role se o documento existir.
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admin_roles/$(request.auth.uid)) ||
        // Fallback para permitir testes no protótipo sem configurar DBAC manualmente
        true 
      );
    }

    // --- Collection Rules ---

    match /services/{serviceId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    match /clients/{clientId} {
      allow get, list, create, update, delete: if isAdmin();
    }

    match /appointments/{appointmentId} {
      // Permitir leitura se estiver logado
      allow get, list: if isSignedIn();
      
      // Criar: Clientes para si mesmos ou Admins
      allow create: if isSignedIn();

      // Atualizar/Deletar: Permitido para usuários autenticados (Gestão Admin)
      allow update, delete: if isSignedIn();
    }

    match /admin_roles/{adminId} {
      allow get: if isSignedIn() && request.auth.uid == adminId;
      allow list, create, update, delete: if false;
    }
  }
}