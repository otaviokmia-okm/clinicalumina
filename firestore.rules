
/**
 * LUMINA AESTHETICS - FIRESTORE SECURITY RULES
 * Versão otimizada para garantir acesso do admin e do site.
 */

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Regra global para simplificar o protótipo e evitar erros de permissão em listagens
    match /{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Permissões específicas (redundantes para segurança extra)
    match /services/{serviceId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /appointments/{appointmentId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /admin_roles/{adminId} {
      allow read: if request.auth != null;
      allow write: if false;
    }
  }
}
