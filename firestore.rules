
/**
 * LUMINA AESTHETICS - FIRESTORE SECURITY RULES (PROTOTYPE VERSION)
 *
 * Ajustado para permitir que visitantes vejam horários ocupados
 * e administradores gerenciem a agenda.
 */

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      // Para o protótipo, permitimos acesso administrativo se estiver logado
      // No futuro, verificaríamos o documento em admin_roles
      return isSignedIn();
    }

    // --- Collection Rules ---

    match /services/{serviceId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    match /clients/{clientId} {
      allow get, list, create, update, delete: if isAdmin();
    }

    match /appointments/{appointmentId} {
      // Permitir leitura pública para que o calendário mostre horários ocupados (busy slots)
      // Nota: Adicionado comentário para forçar redeploy das regras.
      allow get, list: if true;
      
      // Criar: Qualquer pessoa autenticada (anônima ou não)
      allow create: if isSignedIn();

      // Atualizar/Deletar: Apenas Administradores (ou usuário logado para fins de protótipo)
      allow update, delete: if isSignedIn();
    }

    match /admin_roles/{adminId} {
      allow get: if isSignedIn() && request.auth.uid == adminId;
      allow list, create, update, delete: if false;
    }
  }
}
